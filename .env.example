# --- Supabase Edge Functions (hosted) ---
# These are NOT read from listing-admin/.env or any local file at runtime.
# Set them in the Dashboard: Project Settings → Edge Functions → Secrets,
# or: supabase secrets set --env-file supabase/edge-secrets.env --project-ref YOUR_PROJECT_REF
# See supabase/edge-secrets.env.example for names. Required for eBay OAuth at minimum:
# EBAY_APP_ID, EBAY_CERT_ID (or EBAY_CLIENT_SECRET), EBAY_OAUTH_REDIRECT_URL
# EBAY_USE_SANDBOX=true if keys are from the eBay Sandbox tab (fixes unauthorized_client for SBX apps)
# EBAY_OAUTH_SCOPES=... optional override; scope URIs must use .../oauth/api_scope/sell.* not .../oauth/sell.*

# listing-admin (Vite only)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# listing-pipeline CLI
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_key
LISTING_EMAIL=operator@example.com
LISTING_PASSWORD=secret

# Optional Edge secrets (same Dashboard / CLI as above)
# LISTING_CRON_SECRET, EBAY_DEFAULT_CATEGORY_ID, LISTING_EBAY_SAMPLE_MIN, TCGPLAYER_API_KEY
# MARKET_COMPS_* / LISTING_CRON_SECRET — see supabase/edge-secrets.env.example
