# Copy to edge-secrets.env (gitignored), fill in, then:
#   supabase secrets set --env-file supabase/edge-secrets.env --project-ref YOUR_PROJECT_REF
#
# Names must match what Edge Functions read (see ebay-oauth-start, ebay-oauth-callback).

# Production eBay APIs by default. Set only true for Sandbox tab keys:
# EBAY_USE_SANDBOX=true

# Client ID + secret for OAuth and for Browse API client-credentials (market-comps-ingest).
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_OAUTH_REDIRECT_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/ebay-oauth-callback

# Optional: paste the exact space-separated scope list from Developer Portal → Application Keys → User Tokens → "See all".
# EBAY_OAUTH_SCOPES=https://api.ebay.com/oauth/api_scope https://api.ebay.com/oauth/api_scope/sell.inventory

# Sold-search keyword order (other flows):
# LISTING_EBAY_SOLD_QUERY_LANGUAGE=en
# LISTING_EBAY_FINDING_MAX_ATTEMPTS=5
# LISTING_EBAY_FINDING_RETRY_MS=4000

# Cron (GitHub Actions for market-comps-ingest, etc.) — optional for CLI / manual curl
LISTING_CRON_SECRET=

# market-comps-ingest (optional; defaults in code — tuned to avoid Edge WORKER_LIMIT)
# MARKET_COMPS_CRON_SECRET=   # falls back to LISTING_CRON_SECRET
# MARKET_COMPS_ORDER=stale   # stale = coldest comps first (keyset); id = legacy offset order
# MARKET_COMPS_OFFSET=0
# MARKET_COMPS_BATCH_SIZE=1
# MARKET_COMPS_MAX_SEARCHES=3
# MARKET_COMPS_BROWSE_LIMIT=10
# MARKET_COMPS_MAX_LISTINGS_PER_SEARCH=3
# MARKET_COMPS_SEARCH_DELAY_MS=1500   # ms between Browse searches (raise if eBay 2001; lower helps avoid Edge WORKER_LIMIT)
# MARKET_COMPS_BROWSE_MAX_RETRIES=4    # eBay rate-limit retries per search (default 4; lower to 3 to reduce Edge CPU/time)
#
# market-comps-card-fetch (on-demand BIN when user opens card detail — default cooldown 15 minutes)
# MARKET_COMPS_CARD_COOLDOWN_MINUTES=15
#
# Historical comps + tier cadence live in Postgres: market_rss_active_observations, market_sold_comp_snapshots,
# pokemon_card_market_refresh. Tier hints: run SQL `select public.recompute_pokemon_market_tiers(500, 100);`
# periodically (e.g. nightly) via cron or CI; thresholds = min |Δprice| cents for hot vs cold.

# market-sold-comps-ingest (Finding API findCompletedItems — EBAY_APP_ID only)
# MARKET_SOLD_COMPS_CRON_SECRET=   # falls back to LISTING_CRON_SECRET
# MARKET_SOLD_COMPS_ORDER=stale
# MARKET_SOLD_COMPS_OFFSET=0
# MARKET_SOLD_COMPS_BATCH_SIZE=1
# MARKET_SOLD_COMPS_MAX_SEARCHES=3
# MARKET_SOLD_COMPS_FINDING_LIMIT=100
# MARKET_SOLD_COMPS_SEARCH_DELAY_MS=0

# pokemon-card-images-ingest (tcgcsv.com → TCGPlayer product catalog; category 3 = Pokémon)
# Optional: TCGdex API base (no trailing slash) for series display names — https://tcgdex.dev/
# Fetches GET {TCGDEX_API_BASE}/en/series on each catalog ingest batch.
# TCGDEX_API_BASE=https://api.tcgdex.net/v2
# TCGCSV_CATEGORY_BASE=https://tcgcsv.com/tcgplayer/3
# Groups per Edge invocation — keep low (e.g. 2–6) to avoid WORKER_LIMIT on large product sets.
# POKEMON_CARD_IMAGES_GROUPS_PER_RUN=4
# Delay between group fetches (ms).
# POKEMON_CARD_IMAGES_GROUP_DELAY_MS=150
# POKEMON_CARD_IMAGES_CRON_SECRET=
